# Copy this file to root .env before running Docker Compose.
# REQUIRED: replace every value marked REQUIRED before production deployment.

POSTGRES_DB=netops_agenticops
POSTGRES_USER=netops
# REQUIRED: use `openssl rand -hex 24`; keep URL-safe characters.
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=5173
# REQUIRED: public browser origin, normally the same HTTPS origin as AUTH_PUBLIC_BASE_URL.
FRONTEND_URL=https://agenticops.example.com
DEBUG=False
LOG_LEVEL=INFO
LOG_JSON=True
# REQUIRED: use `openssl rand -hex 32`; do not rotate without a secret migration plan.
APP_SECRET_KEY=replace_with_a_long_random_secret
# REQUIRED SAFETY DEFAULT: keep True throughout initial validation and 14-day Shadow Mode.
AUTOMATION_OBSERVE_ONLY=True
# Bounded multi-agent diagnostic graph. Keep conservative defaults initially.
AGENT_GRAPH_LEASE_SECONDS=60
AGENT_MAX_RUNS_PER_CASE=16
AGENT_MAX_LLM_CALLS_PER_CASE=8
AGENT_MAX_TOOL_CALLS_PER_CASE=12
AGENT_MAX_PROBE_CALLS_PER_CASE=10
AGENT_MAX_REPLAN_COUNT=3
AGENT_MAX_RUNTIME_SECONDS=900
AGENT_MAX_TARGET_DEVICES=3
AGENT_MAX_TOOL_CALLS_PER_RUN=3
HYPOTHESIS_CONFIRM_CONFIDENCE=0.75
HYPOTHESIS_EVIDENCE_MAX_AGE_SECONDS=3600
HYPOTHESIS_MAX_HIGH_WEIGHT_CONTRADICTIONS=0
# REQUIRED: public HTTPS root URL used to build OIDC/SAML callbacks.
AUTH_PUBLIC_BASE_URL=https://agenticops.example.com
# REQUIRED SAFETY DEFAULT for production HTTPS.
AUTH_COOKIE_SECURE=True
ELK_INGESTION_PAGE_SIZE=500
ELK_CHECKPOINT_LEASE_SECONDS=120
# Webhook targets must be public HTTPS endpoints; this does not enable private IP targets.
WEBHOOK_ALLOW_HTTP=False

# OPTIONAL: leave an integration empty and configure it later in the UI.
NETBOX_URL=
NETBOX_API_TOKEN=

ELK_URL=
ELK_USERNAME=
ELK_PASSWORD=

ZABBIX_URL=
ZABBIX_API_URL=
ZABBIX_USERNAME=
ZABBIX_PASSWORD=

LLM_MODEL_NAME=Qwen/Qwen3-32B-AWQ
LLM_API_KEY=
LLM_API_URL=http://host.docker.internal:8000/v1
LLM_EMBEDDING_MODEL=
LLM_EMBEDDING_API_URL=
