# App Configuration
APP_SECRET_KEY=replace_with_a_long_random_secret

# NetBox Configuration
NETBOX_URL=https://netbox.example.com
NETBOX_API_TOKEN=replace_with_netbox_token

# ELK Configuration
ELK_URL=https://elk.example.com
ELK_USERNAME=elastic
ELK_PASSWORD=replace_with_elk_password

# Zabbix Configuration
ZABBIX_URL=https://zabbix.example.com
ZABBIX_API_URL=https://zabbix.example.com/api_jsonrpc.php
ZABBIX_USERNAME=Admin
ZABBIX_PASSWORD=replace_with_zabbix_password

# Local LLM Configuration
LLM_MODEL_NAME=Qwen/Qwen3-32B-AWQ
LLM_API_KEY=replace_with_llm_api_key
LLM_API_URL=http://llm.example.com/v1

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True
LOG_LEVEL=INFO
LOG_JSON=True
LOG_FILE_ENABLED=False

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
AUTH_PUBLIC_BASE_URL=https://agenticops.example.com
AUTH_COOKIE_SECURE=True

# Database Configuration
DATABASE_URL=postgresql://netops:replace_with_password@127.0.0.1:5432/netops_agenticops

# Data Retention (days)
RETENTION_RAW_ANOMALY_DAYS=30
RETENTION_LOG_SAMPLE_DAYS=30
RETENTION_ANALYSIS_DAYS=60
RETENTION_AUTOMATION_TASK_DAYS=90
RETENTION_ACTION_LOG_DAYS=90
RETENTION_APPROVAL_DAYS=180
RETENTION_FEEDBACK_DAYS=180
RETENTION_TRACKER_STATE_DAYS=7

# Safety Mode
AUTOMATION_OBSERVE_ONLY=True
AGENT_GRAPH_LEASE_SECONDS=60
AGENT_MAX_RUNS_PER_CASE=16
AGENT_MAX_LLM_CALLS_PER_CASE=8
AGENT_MAX_TOOL_CALLS_PER_CASE=12
AGENT_MAX_PROBE_CALLS_PER_CASE=10
AGENT_MAX_REPLAN_COUNT=3
AGENT_MAX_RUNTIME_SECONDS=900
AGENT_MAX_TARGET_DEVICES=3
AGENT_MAX_TOOL_CALLS_PER_RUN=3
HYPOTHESIS_CONFIRM_CONFIDENCE=0.75
HYPOTHESIS_EVIDENCE_MAX_AGE_SECONDS=3600
HYPOTHESIS_MAX_HIGH_WEIGHT_CONTRADICTIONS=0
PROBE_GLOBAL_CONCURRENCY=20
PROBE_COMMAND_TIMEOUT_SECONDS=20
ELK_INGESTION_PAGE_SIZE=500
ELK_CHECKPOINT_LEASE_SECONDS=120
ELK_INITIAL_LOOKBACK_HOURS=1
WEBHOOK_ALLOW_HTTP=False

# Ticket System Integration
TICKET_MODE=local
TICKET_SYSTEM_BASE_URL=
TICKET_SYSTEM_API_KEY=
TICKET_SYSTEM_TIMEOUT_SECONDS=15

# Splunk Webhook Integration
SPLUNK_WEBHOOK_TOKEN=

# Ansible EDA Webhook Integration
EDA_WEBHOOK_TOKEN=
