          "commands": ["display cpu-usage"],
          "severity": "warning",
          "threshold": {"max": 80, "critical": 90},
          "device_types": ["huawei", "h3c", "cisco"],
          "enabled": true
        },
        {
          "item_id": "memory_usage",
