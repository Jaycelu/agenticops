[Unit]
Description=AgenticOps Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/path/to/agenticops/backend
Environment="PATH=/usr/bin:/usr/local/bin"
ExecStartPre=/usr/bin/python3 -m alembic -c /path/to/agenticops/backend/alembic.ini upgrade head
ExecStart=/usr/bin/python3 /path/to/agenticops/backend/main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
